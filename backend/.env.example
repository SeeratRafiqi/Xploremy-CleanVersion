# Supabase (events_chatbot, Fan DNA tables — use service role on server)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_KEY=

# Fan DNA admin dashboard (/admin) — comma-separated account emails
# ADMIN_EMAILS=you@example.com

# Sign-in / sign-up (cookie sessions; change in production)
# SESSION_SECRET=

# Password reset emails (optional). Without SMTP, reset links are logged to the
# server console instead of emailed. Used by /api/auth/forgot-password.
# PUBLIC_BASE_URL=https://your-domain.com   # used to build the reset link (falls back to request host)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Event Explorer <no-reply@your-domain.com>"
# NOTE: SMTP delivery requires nodemailer: npm i nodemailer

# Alibaba Cloud Model Studio / DashScope (recommended for chatbot)
DASHSCOPE_API_KEY=
# Optional: Singapore default. China: https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus
# Trip Planner: max wait for DashScope (ms), default 180000 (3 min)
# DASHSCOPE_ITINERARY_TIMEOUT_MS=240000

# Optional fallback
# ANTHROPIC_API_KEY=

# Google Gemini — primary LLM for chatbot + event detail Q&A (DashScope fallback)
# Get a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Trip Planner: Unsplash search for place images (https://unsplash.com/oauth/applications)
# UNSPLASH_ACCESS_KEY=
# Alias (same value as access key / client id):
# UNSPLASH_API_KEY=
# Trip Planner image sources (no Wikipedia key needed):
# 1) English Wikipedia pageimages
# 2) Wikimedia Commons search
# 3) Unsplash (if UNSPLASH_ACCESS_KEY or UNSPLASH_API_KEY is set)

# Trip Planner: optional live open/closed checks
# GOOGLE_PLACES_API_KEY=

# SerpAPI Google Flights — server proxy at GET /api/flights (key never sent to browser; do not call SerpAPI from frontend)
# https://serpapi.com/ — create key in dashboard
# VITE_SERPAPI_KEY=
# Optional alias (same value):
# SERPAPI_KEY=

# AirLabs API (flight schedules in Trip Planner — server reads this for /api/airlabs/schedules)
# https://airlabs.co/ — same name works if you add Vite later (import.meta.env.VITE_AIRLABS_API_KEY)
# VITE_AIRLABS_API_KEY=

# --- Amadeus Hotel List (official API; free dev tier) — npm run scrape:hotels:amadeus
# Create app: https://developers.amadeus.com/my-apps
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# test (default) or production
# AMADEUS_ENV=test
# by-city (default) or geocode
# AMADEUS_HOTEL_MODE=city
# IATA city code (default Kuala Lumpur)
# AMADEUS_HOTEL_CITY_CODE=KUL
# Optional: narrow by radius from city center (API params)
# AMADEUS_HOTEL_RADIUS=50
# AMADEUS_HOTEL_RADIUS_UNIT=KM
# For AMADEUS_HOTEL_MODE=geocode — hotels near a point (e.g. event venue)
# AMADEUS_HOTEL_LAT=
# AMADEUS_HOTEL_LNG=
# AMADEUS_HOTEL_SOURCE=ALL
